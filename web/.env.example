# Supabase environment example for local development
# Copy this file to .env.local and fill in real values (DO NOT commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...
SUPABASE_STORAGE_BUCKET=imports

# Notes:
# - SUPABASE_SERVICE_ROLE_KEY must be kept secret and only used in server-side environment (API routes).
# - For local development you can place these values in web/.env.local (gitignored).
