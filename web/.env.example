# Supabase environment example for local development
# Copy this file to .env.local and fill in real values (DO NOT commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...
SUPABASE_STORAGE_BUCKET=imports

# 2Factor SMS (WhatsApp is sent via Way2Smart below)
TWOFACTOR_API_KEY=your_2factor_api_key
TWOFACTOR_SENDER_ID=VEDANT

# Way2Smart WhatsApp (template API: POST {WAY2SMART_BASE_URL}/{phone_number_id}/messages, header apikey)
# From Postman: console-api.way2smart.in/v3/{{phone_number_id}}/messages
WAY2SMART_API_KEY=your_way2smart_api_key
WAY2SMART_PHONE_NUMBER_ID=your_phone_number_id
# Optional; default https://console-api.way2smart.in/v3
# WAY2SMART_BASE_URL=https://console-api.way2smart.in/v3
# Template language code (e.g. mr, en_US)
WAY2SMART_TEMPLATE_LANG=mr

# Approved Way2Smart template NAMES (must match dashboard exactly)
# Thorath / ticket messages: body {{1}} = ticket e.g. VED-000016
# Used for voter copy on create + per-status updates.
WAY2SMART_TEMPLATE_SERVICE_REQUEST_CREATED=document_submitted
WAY2SMART_TEMPLATE_SERVICE_REQUEST_AUTO_ADVANCED_SHARED=document_shared_to_office
WAY2SMART_TEMPLATE_SERVICE_REQUEST_AUTO_ADVANCED_WIP=work_completed
WAY2SMART_TEMPLATE_SERVICE_REQUEST_STATUS_CHANGED=closed_delivered
# Daily cron (optional; omit or leave empty to skip WhatsApp for that job)
# WAY2SMART_TEMPLATE_BIRTHDAY_GREETING=
# WAY2SMART_TEMPLATE_ANNIVERSARY_GREETING=

# Vedant office lines: body {{1}} = श्री. … (मो. …), {{2}} = e.g. रेशन कार्डचे
# Used for office copy on create/complete.
# Submission: "… येथे {{1}} यांचे {{2}} काम जमा करण्यात आले आहे."
# Complete:   "… येथे {{1}} यांचे {{2}} काम पूर्ण करण्यात आले आहे."
WAY2SMART_TEMPLATE_VEDANT_WORK_SUBMITTED=vedant_work_submitted
WAY2SMART_TEMPLATE_VEDANT_WORK_COMPLETED=vedant_work_completed

# WhatsApp copy of Vedant messages to this number (10 digits or 91…). Example: 8412865555
VEDANT_OFFICE_NOTIFY_WHATSAPP=8412865555

# Birthday PDF letterhead (optional overrides; defaults use web/assets/letterhead-birthday.pdf)
# Greeting text is rendered via @napi-rs/canvas (Skia) then embedded as PNG — not pdf-lib drawText.
# BIRTHDAY_LETTERHEAD_PDF_PATH=assets/letterhead-birthday.pdf
# Optional: path to Anek WOFF/TTF for greeting overlay (default: public/fonts anek-devanagari-devanagari-400-normal.woff)
# BIRTHDAY_GREETING_FONT_PATH=public/fonts/anek-devanagari-devanagari-400-normal.woff
# BIRTHDAY_GREETING_X=28
# (left edge of overlay in PDF pt; align with body gutter)
# BIRTHDAY_GREETING_TOP_FROM_PAGE_TOP_PT=290
# (pt down from page top to top of overlay; larger = lower on page, closer to “आपणास …” line)
# BIRTHDAY_GREETING_Y=
# (optional: absolute PDF y of TOP of image; if set, overrides TOP_FROM_PAGE_TOP_PT)
# BIRTHDAY_GREETING_CANVAS_PX=34
# (canvas font size in px; lines: प्रति, / name / village)
# BIRTHDAY_GREETING_CANVAS_LINE_PX=46
# (canvas baseline-to-baseline px between lines)
# BIRTHDAY_GREETING_IMAGE_SCALE=0.5
# (PNG px to PDF pt scale when drawing on the page; date line uses the same scale)
# Date line: default Marathi दि. DD/MM/YYYY (Devanagari digits); format constant in pages/api/voter-profiles/[id]/birthday-pdf.ts

# Notes:
# - SUPABASE_SERVICE_ROLE_KEY must be kept secret and only used in server-side environment (API routes).
# - For local development you can place these values in web/.env.local (gitignored).
